{
    "swagger": "2.0",
    "info": {
        "description": "Backend API for Flutter Chat App.",
        "title": "Go Chat App API",
        "contact": {},
        "version": "1.0"
    },
    "paths": {
        "/api/v1/auth/activate/{link}": {
            "get": {
                "description": "Activation of account after registration step",
                "consumes": [
                    "text/plain"
                ],
                "produces": [
                    "text/html"
                ],
                "tags": [
                    "Registration"
                ],
                "summary": "Activate",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Generated link's end side edge",
                        "name": "link",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "201": {
                        "description": "Returns the html page of success",
                        "schema": {
                            "type": "string"
                        }
                    },
                    "400": {
                        "description": "Could not get the link from url path. Possible \"error\" values : [BAD_REQUEST]",
                        "schema": {
                            "$ref": "#/definitions/utils.ErrorResponse"
                        }
                    },
                    "410": {
                        "description": "Activation link is expired . Possible \"error\" values : [ACTIVATION_TIME_EXPIRED]",
                        "schema": {
                            "$ref": "#/definitions/utils.ErrorResponse"
                        }
                    },
                    "500": {
                        "description": "Server failed to process . Possible \"error\" values : [INTERNAL_SERVER_ERROR]",
                        "schema": {
                            "$ref": "#/definitions/utils.ErrorResponse"
                        }
                    }
                }
            }
        },
        "/api/v1/auth/login": {
            "post": {
                "description": "Basic Login operation with email and password",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Authentication"
                ],
                "summary": "Login",
                "parameters": [
                    {
                        "description": "Provide your creds for creation new session on certain device",
                        "name": "payload",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/auth_handlers.loginRequest"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Session was successfully created",
                        "schema": {
                            "$ref": "#/definitions/auth_handlers.AuthResponse"
                        }
                    },
                    "400": {
                        "description": "Possible \"error\" values: [EMPTY_AUTH_CREDS] ",
                        "schema": {
                            "$ref": "#/definitions/utils.ErrorResponse"
                        }
                    },
                    "401": {
                        "description": "Possible \"error\" values: [INVALID_CREDS, \"any\tother\tprintable\terrors\"]",
                        "schema": {
                            "$ref": "#/definitions/utils.ErrorResponse"
                        }
                    },
                    "500": {
                        "description": "Server failed to process . Possible \"error\" values : [INTERNAL_SERVER_ERROR]",
                        "schema": {
                            "$ref": "#/definitions/utils.ErrorResponse"
                        }
                    }
                }
            }
        },
        "/api/v1/auth/logout": {
            "post": {
                "description": "Logging out by revoking session",
                "consumes": [
                    "text/plain"
                ],
                "produces": [
                    "text/plain"
                ],
                "tags": [
                    "Authorization"
                ],
                "summary": "Log out",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Insert 'Bearer \u003cAccessToken\u003e'",
                        "name": "Authorization",
                        "in": "header",
                        "required": true
                    }
                ],
                "responses": {
                    "204": {
                        "description": "Logged out successfully"
                    },
                    "401": {
                        "description": "Possible \"error\" values: [EMPTY_AUTH_CREDS]",
                        "schema": {
                            "$ref": "#/definitions/utils.ErrorResponse"
                        }
                    },
                    "500": {
                        "description": "Server failed to process . Possible \"error\" values : [INTERNAL_SERVER_ERROR]",
                        "schema": {
                            "$ref": "#/definitions/utils.ErrorResponse"
                        }
                    }
                }
            }
        },
        "/api/v1/auth/me": {
            "get": {
                "description": "Endpoint for checking authorization",
                "consumes": [
                    "text/plain"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Profile"
                ],
                "summary": "Checking authorization",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Insert 'Bearer \u003cyour_token\u003e'",
                        "name": "Authorization",
                        "in": "header",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "user_id\": some_user_id (int)",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    },
                    "500": {
                        "description": "Possible \"error\" values: [INTERNAL_SERVER_ERROR]",
                        "schema": {
                            "$ref": "#/definitions/utils.ErrorResponse"
                        }
                    }
                }
            }
        },
        "/api/v1/auth/refresh": {
            "post": {
                "description": "Get new pair of token",
                "consumes": [
                    "text/plain"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Authorization"
                ],
                "summary": "refresh",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Insert 'Bearer \u003cRefreshToken\u003e'",
                        "name": "Authorization",
                        "in": "header",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "New refreshed token pair returned. So update them both",
                        "schema": {
                            "$ref": "#/definitions/auth_handlers.AuthResponse"
                        }
                    },
                    "401": {
                        "description": "Possible \"error\" values: [INVALID_CREDS,\"all\tother\terrors\"]",
                        "schema": {
                            "$ref": "#/definitions/utils.ErrorResponse"
                        }
                    },
                    "500": {
                        "description": "Server failed to process . Possible \"error\" values : [INTERNAL_SERVER_ERROR]",
                        "schema": {
                            "$ref": "#/definitions/utils.ErrorResponse"
                        }
                    }
                }
            }
        },
        "/api/v1/auth/register": {
            "post": {
                "description": "For initiating registration process with sending activation link",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Registration"
                ],
                "summary": "Register",
                "parameters": [
                    {
                        "description": "User registration details",
                        "name": "payload",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/auth_handlers.registerRequest"
                        }
                    }
                ],
                "responses": {
                    "201": {
                        "description": "Activation link is successfully sent"
                    },
                    "400": {
                        "description": "Request is invalid. Possible \"error\" values:[USER_ALREADY_EXISTS,\"all\tothers\tare\tcaused\tby\tthe\trequest's\tincorrectness\"]",
                        "schema": {
                            "$ref": "#/definitions/utils.ErrorResponse"
                        }
                    },
                    "500": {
                        "description": "Server failed to process. Possible \"error\" values : [INTERNAL_SERVER_ERROR]",
                        "schema": {
                            "$ref": "#/definitions/utils.ErrorResponse"
                        }
                    }
                }
            }
        },
        "/api/v1/chats/create": {
            "post": {
                "description": "Initiates a new chat between two users or returns existing. If a 1-to-1 chat already exists between these users, it returns the existing chat details.",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "chats"
                ],
                "summary": "Create or get a 1-to-1 chat",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Insert 'Bearer \u003cAccessToken\u003e'",
                        "name": "Authorization",
                        "in": "header",
                        "required": true
                    },
                    {
                        "description": "Create Chat Request",
                        "name": "request",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/chat_handlers.CreateChatRequest"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Successfully created or retrieved chat",
                        "schema": {
                            "$ref": "#/definitions/chat_handlers.CreateChatResponse"
                        }
                    },
                    "400": {
                        "description": "Invalid request body or missing fields",
                        "schema": {
                            "$ref": "#/definitions/utils.ErrorResponse"
                        }
                    },
                    "500": {
                        "description": "Internal server error",
                        "schema": {
                            "$ref": "#/definitions/utils.ErrorResponse"
                        }
                    }
                }
            }
        },
        "/api/v1/users/active": {
            "get": {
                "description": "Returns an array of all currently connected User IDs.",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "users"
                ],
                "summary": "List active users",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Insert 'Bearer \u003cAccessToken\u003e'",
                        "name": "Authorization",
                        "in": "header",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/chat_handlers.ActiveUsersResponse"
                        }
                    }
                }
            }
        },
        "/ws": {
            "get": {
                "description": "Initiates a WebSocket connection. Requires user_id in query.",
                "tags": [
                    "websocket"
                ],
                "summary": "Upgrade to WebSocket",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Insert 'Bearer \u003cAccessToken\u003e'",
                        "name": "Authorization",
                        "in": "header",
                        "required": true
                    },
                    {
                        "type": "string",
                        "description": "User ID",
                        "name": "user_id",
                        "in": "query",
                        "required": true
                    }
                ],
                "responses": {
                    "101": {
                        "description": "Switching Protocols",
                        "schema": {
                            "type": "string"
                        }
                    }
                }
            }
        }
    },
    "definitions": {
        "auth_handlers.AuthResponse": {
            "type": "object",
            "properties": {
                "access_token": {
                    "type": "string"
                },
                "refresh_token": {
                    "type": "string"
                }
            }
        },
        "auth_handlers.loginRequest": {
            "type": "object",
            "required": [
                "email",
                "password"
            ],
            "properties": {
                "email": {
                    "type": "string",
                    "example": "user@example.com"
                },
                "password": {
                    "type": "string",
                    "example": "P@ssword123"
                }
            }
        },
        "auth_handlers.registerRequest": {
            "type": "object",
            "required": [
                "email",
                "password"
            ],
            "properties": {
                "email": {
                    "type": "string",
                    "example": "user@example.com"
                },
                "password": {
                    "type": "string",
                    "minLength": 8,
                    "example": "P@ssword123"
                }
            }
        },
        "chat_handlers.ActiveUsersResponse": {
            "type": "object",
            "properties": {
                "active_users": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    },
                    "example": [
                        "user_1",
                        "user_2"
                    ]
                }
            }
        },
        "chat_handlers.CreateChatRequest": {
            "type": "object",
            "required": [
                "receiver_id",
                "sender_id"
            ],
            "properties": {
                "receiver_id": {
                    "type": "string"
                },
                "sender_id": {
                    "type": "string"
                }
            }
        },
        "chat_handlers.CreateChatResponse": {
            "type": "object",
            "properties": {
                "chat_id": {
                    "type": "string"
                },
                "chat_name": {
                    "type": "string"
                }
            }
        },
        "utils.ErrorResponse": {
            "type": "object",
            "properties": {
                "error": {
                    "type": "string"
                }
            }
        }
    }
}